  <title>Cluster</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="https://cdn.maptiler.com/maptiler-sdk-js/v3.10.2/maptiler-sdk.umd.min.js"></script>
  <link href="https://cdn.maptiler.com/maptiler-sdk-js/v3.10.2/maptiler-sdk.css" rel="stylesheet" />
  <script src="https://cdn.maptiler.com/leaflet-maptilersdk/v4.1.0/leaflet-maptilersdk.umd.min.js"></script>
  <!-- Leaflet.MarkerCluster -->
  <script src='https://cdnjs.cloudflare.com/ajax/libs/leaflet.markercluster/1.5.3/leaflet.markercluster.js'></script>
  <link href='https://cdnjs.cloudflare.com/ajax/libs/leaflet.markercluster/1.5.3/MarkerCluster.css' rel='stylesheet' />
  <link href='https://cdnjs.cloudflare.com/ajax/libs/leaflet.markercluster/1.5.3/MarkerCluster.Default.css' rel='stylesheet' />
  <style>
    #map {position: absolute; top: 0; right: 0; bottom: 0; left: 0;}
  </style>


	<div id="map"></div>



	<script>


    const key = "{{viewData.mapsApiKey}}";
    const map = new L.Map('map', {maxZoom: 22}).setView([53.5, -8],7);

    const mtLayer = L.maptiler.maptilerLayer({
      style: L.maptiler.MapStyle.DATAVIZ.LIGHT,
      apiKey: key,
    }).addTo(map);

    const markers = L.markerClusterGroup();

    (async () => {
      const points = {{{ viewData.pointsJson }}};
      
      for (let i = 0; i < points.length; i++) {
        console.log(points[i].data.name);
        const p = points[i];
        const title = p.data.name;
        const description = p.data.description;
        const marker = L.marker(new L.LatLng(p.pos.lat, p.pos.lon),{ title: title }, { description: description });
        const popupContent = `
                                <p><strong style="color: black">${title}</strong></p>
                                <p>${description}</p>
                                <p>added on ${p.data.time.created}</p>
                                `
        marker.bindPopup(popupContent);
        markers.addLayer(marker);
      }

      map.addLayer(markers);
    })();

	</script>
