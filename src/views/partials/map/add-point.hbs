<form class="container pt-5 pb-5" style="max-width: 600px;" method="POST" action="/dashboard/add-point/submit">
  <div class="field">
    <label class="label">Lat <span style="color: red;">*</span></label>
    <div class="control">
      <input class="input" type="text" placeholder="" required name="lat" />
    </div>
  </div>

  <div class="field">
    <label class="label">Lon <span style="color: red;">*</span></label>
    <div class="control">
      <input class="input" type="text" placeholder="" required name="lon" />
    </div>
  </div>
  <div class="field">
    <label class="label">Name <span style="color: red;">*</span></label>
    <div class="control">
      <input class="input" type="text" placeholder="" required name="name" />
    </div>
  </div>
  <div class="field">
    <label class="label">Description</label>
    <div class="control">
      <input class="input" type="text" placeholder="" name="description" />
    </div>
  </div>
  <div class="field">
    <label class="label">Categories</label>
    <div class="control">
      <input class="input" type="text" placeholder="" name="categories" />
    </div>
  </div>

<div class="is-flex is-flex-direction-row is-justify-content-space-between is-align-items-center">
  <button class="button is-primary">Submit</button>
  <div class="div {{viewData.infoClass}}">{{viewData.infoMessage}}</div>
</div>
</form>